MARKET_PDF_INSIGHTS_CLIENT=placeholder
MARKET_PDF_INSIGHTS_MODEL=gpt-4.1-mini

# Required when MARKET_PDF_INSIGHTS_CLIENT=openai or CLI uses --llm openai.
# OPENAI_API_KEY=

# Optional future Pivot 2 public-source connector credentials.
# FRED_API_KEY=
# NEWSAPI_KEY=

# Optional Pivot 3 private UI password hash. Generate with hash_private_password(...).
# MARKET_PRIVATE_UI_PASSWORD_HASH=

# Optional future Pivot 3 Under the Radar automation gate.
# Leave disabled unless subscription terms explicitly permit the exact access pattern.
# UNDERTHERADAR_CONNECTOR_ENABLED=false
# UNDERTHERADAR_USERNAME=
# UNDERTHERADAR_PASSWORD=
